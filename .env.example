# Port the HTTP + WebSocket server listens on.
PORT=3000

# Override if you're running your own adsb.lol / adsbdb.com-compatible mirror.
# ADSB_BASE_URL=https://api.adsb.lol/v2
# ADSBDB_BASE_URL=https://api.adsbdb.com/v0

# Primary route source: adsb.lol's vrs-standing-data (per-callsign JSON with
# airport coordinates). Set VRS_ENABLED=false to skip it and start from adsbdb.
# VRS_BASE_URL=https://vrs-standing-data.adsb.lol
# VRS_ENABLED=true

# ADS-B position sources are tried in order: adsb.lol -> adsb.fi -> airplanes.live.
# On a 429 the server fails over to the next and puts the throttled one on a
# cooldown (seconds below) before retrying it. Bases are overridable too.
# ADSBFI_BASE_URL=https://opendata.adsb.fi/api
# AIRPLANESLIVE_BASE_URL=https://api.airplanes.live/v2
# ADSB_SOURCE_COOLDOWN_MS=60000

# How often (ms) each active watch zone polls adsb.lol.
# Lower = more live, but too low will trip adsb.lol's rate limit (HTTP 429).
# ADSB_POLL_MS=10000

# Identify yourself to adsb.lol (their etiquette). Put your own contact/URL here;
# unidentified clients get throttled harder.
# ADSB_USER_AGENT=SkyPane/1.0 (you@example.com)

# ── Backup route source: airframes.io ────────────────────────────────────────
# Used only as a FALLBACK when adsbdb's route is missing or inconsistent with the
# aircraft's live position. Requires an Airframes API key (they gate access to
# feeders / paid accounts — see https://docs.airframes.io/api/). Leave the key
# empty to disable the backup entirely; the route is then simply suppressed when
# adsbdb's is untrustworthy.
# AIRFRAMES_API_KEY=your-airframes-api-key-here
# AIRFRAMES_BASE_URL=https://api.airframes.io/v1

# ── Last-resort route source: FlightAware AeroAPI ────────────────────────────
# Paid, keyed API queried only as the FINAL API layer (after vrs/adsbdb/airframes,
# before the user CSV), so paid queries stay rare and are cached. Get a key from
# https://www.flightaware.com/aeroapi/portal/ and paste it here. Leave empty to
# disable. (AeroAPI routes show origin→destination + city but no DTG/ETA, since
# its flight endpoint doesn't return airport coordinates.)
# AEROAPI_KEY=your-flightaware-aeroapi-key-here
# AEROAPI_BASE_URL=https://aeroapi.flightaware.com/aeroapi

# ── User-supplied route corrections (CSV) ────────────────────────────────────
# Final fallback route source after adsbdb + airframes.io. Add rows to
# data/routes.csv (see data/README.md). Set OVERRIDE=true to make a CSV entry win
# over the APIs whenever one exists for the flight. The file is reloaded
# automatically when it changes (every ROUTES_CSV_RESCAN_MS; 0 disables).
# ROUTES_CSV_PATH=data/routes.csv
# ROUTE_CSV_OVERRIDE=false
# ROUTES_CSV_RESCAN_MS=30000

# ── Airline logos ────────────────────────────────────────────────────────────
# Local logo files go in public/logos/ (named by airline ICAO code, e.g. UAL.png)
# — see public/logos/README.md. New/removed files are picked up automatically
# (every LOGO_RESCAN_MS; 0 disables). Optionally set a remote logo URL template
# with {icao} / {name} placeholders as a fallback (use a source you have rights to).
# LOGO_RESCAN_MS=30000
# AIRLINE_LOGO_URL_TEMPLATE=https://logos.example.com/{icao}.png
